{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@domain/*": ["src/domain/*"],
      "@core/*": ["src/core/*"],
      "@data/*": ["src/data/*"],
      "@state/*": ["src/state/*"],
      "@ui/*": ["src/ui/*"]
    }
  },
  "include": ["src/**/*", "App.tsx", "index.js", "__mocks__/**/*"]
}
